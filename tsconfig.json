{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "lib": [
      "ES2022",
      "DOM",
      "WebWorker"
    ]
  },
  "include": [
    "js/app.js",
    "js/simulator.js",
    "js/worker.js",
    "types/**/*.d.ts"
  ]
}
